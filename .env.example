DJANGO_SECRET_KEY=change-me-with-a-long-random-secret

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Option A: full connection string (takes priority - use for Supabase/production)
# DATABASE_URL=postgresql://postgres.YOURPROJECT:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Option B: individual vars (used when DATABASE_URL is not set - Docker/local)
DATABASE_NAME=codeleap_db
DATABASE_USER=codeleap_user
DATABASE_PASSWORD=change-me-db-password
# Use 127.0.0.1 for local setup, or 'db' when running via Docker Compose
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# API pagination page size (default: 10)
API_PAGE_SIZE=10
